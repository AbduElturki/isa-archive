#include "{{ ns }}_enums.h"

namespace {{ ns }} {

// Instruction word is {{ insn_bits }} bits ({{ insn_bytes }} bytes).
{% if wide %}
// Wider than 64 bits: the raw word is a little-endian byte array.
using Word = std::array<uint8_t, {{ insn_bytes }}>;

// Extract `width` (<= 64) bits starting at bit `start`.
inline uint64_t get_bits(const Word &word, unsigned start, unsigned width) {
    uint64_t r = 0;
    for (unsigned i = 0; i < width; ++i) {
        unsigned b = start + i;
        r |= (uint64_t)((word[b >> 3] >> (b & 7)) & 1u) << i;
    }
    return r;
}

// Extract a field of *any* width into `out` as little-endian bytes (out must hold at
// least (width + 7) / 8 bytes). Use for fields wider than 64 bits — e.g. a structured
// operand — that get_bits can't return; sub-fields up to 64 bits use get_bits.
inline void get_bits_wide(const Word &word, unsigned start, unsigned width, uint8_t *out) {
    for (unsigned i = 0; i < (width + 7) / 8; ++i) out[i] = 0;
    for (unsigned i = 0; i < width; ++i) {
        unsigned b = start + i;
        out[i >> 3] |= (uint8_t)((word[b >> 3] >> (b & 7)) & 1u) << (i & 7);
    }
}

// Sign-extend the low `width` bits of `v`.
inline int64_t sext(uint64_t v, unsigned width) {
    const unsigned s = 64 - width;
    return (int64_t)(v << s) >> s;
}

// Identify an instruction from its raw word (most-specific match first).
inline Op decode(const Word &word) {
{%- for it in decode_order %}
    if ({% for f in it.fixed %}{% if not loop.first %} && {% endif %}get_bits(word, {{ f.start }}, {{ f.width }}) == {{ f.val }}ull{% else %}true{% endfor %}) return Op::{{ it.enum }};
{%- endfor %}
    return Op::INVALID;
}

// Reconstruct the (possibly split, sign-extended) immediate of an instruction.
// Register operands are read via info(op).operands[i] + get_bits().
inline int64_t decode_imm(Op op, const Word &word) {
    switch (op) {
{%- for it in instrs %}{% if it.imm %}
    case Op::{{ it.enum }}:
{%- if it.imm.combined %}
        return sext({% for p in it.imm.parts %}{% if not loop.first %} | {% endif %}(get_bits(word, {{ p.hw_low }}, {{ p.hw_width }}) << {{ p.imm_low }}){% endfor %}, {{ it.imm.width }});
{%- elif it.imm.signed %}
        return sext(get_bits(word, {{ it.imm.start }}, {{ it.imm.width }}), {{ it.imm.width }});
{%- else %}
        return (int64_t)get_bits(word, {{ it.imm.start }}, {{ it.imm.width }});
{%- endif %}{% endif %}{%- endfor %}
    default: return 0;
    }
}
{% else %}
// Extract `width` bits starting at bit `start`.
inline uint64_t get_bits(uint64_t word, unsigned start, unsigned width) {
    return (word >> start) & (width >= 64 ? ~0ULL : ((1ULL << width) - 1));
}

// Sign-extend the low `width` bits of `v`.
inline int64_t sext(uint64_t v, unsigned width) {
    const unsigned s = 64 - width;
    return (int64_t)(v << s) >> s;
}

// Identify an instruction from its raw word (most-specific match first).
inline Op decode(uint64_t word) {
{%- for it in decode_order %}
    if ((word & {{ "0x%xULL" % it.mask }}) == {{ "0x%xULL" % it.match }}) return Op::{{ it.enum }};
{%- endfor %}
    return Op::INVALID;
}

// Reconstruct the (possibly split, sign-extended) immediate of an instruction.
// Register operands are read via info(op).operands[i] + get_bits().
inline int64_t decode_imm(Op op, uint64_t word) {
    switch (op) {
{%- for it in instrs %}{% if it.imm %}
    case Op::{{ it.enum }}:
{%- if it.imm.combined %}
        return sext({% for p in it.imm.parts %}{% if not loop.first %} | {% endif %}(get_bits(word, {{ p.hw_low }}, {{ p.hw_width }}) << {{ p.imm_low }}){% endfor %}, {{ it.imm.width }});
{%- elif it.imm.signed %}
        return sext(get_bits(word, {{ it.imm.start }}, {{ it.imm.width }}), {{ it.imm.width }});
{%- else %}
        return (int64_t)get_bits(word, {{ it.imm.start }}, {{ it.imm.width }});
{%- endif %}{% endif %}{%- endfor %}
    default: return 0;
    }
}
{% endif %}
} // namespace {{ ns }}
