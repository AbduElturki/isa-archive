{% import "_macros.j2" as m %}{{ m.file_header('c', isa_name) }}
#pragma once

#include <cstdint>
{%- for inc in elem_includes %}
#include {{ inc }}
{%- endfor %}

namespace {{ ns }} {

// One enumerator per instruction in the ISA.
enum class Op : uint16_t {
    INVALID = 0,
{%- for it in instrs %}
    {{ it.enum }},
{%- endfor %}
};

inline const char *mnemonic(Op op) {
    switch (op) {
{%- for it in instrs %}
    case Op::{{ it.enum }}: return "{{ it.mnemonic }}";
{%- endfor %}
    default: return "<invalid>";
    }
}

// One enumerator per architectural register file.
enum class RegClass : uint8_t {
    none = 0,
{%- for rc in reg_classes %}
    {{ rc.name }},   // {{ rc.count }} x {% if rc.shape %}{{ rc.shape | join("x") }} {{ rc.element }}{% else %}{{ rc.width }}-bit{{ " (float)" if rc.is_float else "" }}{% endif %}
{%- endfor %}
};

inline const char *reg_class_name(RegClass rc) {
    switch (rc) {
{%- for rc in reg_classes %}
    case RegClass::{{ rc.name }}: return "{{ rc.raw }}";
{%- endfor %}
    default: return "none";
    }
}
{% if elem_types %}
// Element storage type for register files backed by a custom (library) scalar type.
{%- for et in elem_types %}
using {{ et.name }}_elem_t = {{ et.ctype }};
{%- endfor %}
{% endif %}

// Instruction categories, derived from each instruction's exec_type.
enum class Category : uint8_t {
{%- for c in categories %}
    {{ c }},
{%- endfor %}
};

inline const char *category_name(Category c) {
    switch (c) {
{%- for c in categories %}
    case Category::{{ c }}: return "{{ c }}";
{%- endfor %}
    default: return "none";
    }
}

enum class OperandKind : uint8_t { Reg, Imm };

} // namespace {{ ns }}
