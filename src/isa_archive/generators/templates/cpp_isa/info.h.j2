{% import "_macros.j2" as m %}{{ m.file_header('c', isa_name) }}
#pragma once

#include <cstdint>

#include "{{ cls }}Enums.h"

namespace {{ ns }} {

// Description of one operand: where its bits live and how to read it.
struct OperandInfo {
    const char *name;
    uint16_t start;       // least-significant bit position in the instruction word
    uint16_t width;       // bit width
    bool is_signed;       // immediates only
    RegClass rc;          // register class (RegClass::none for immediates)
    OperandKind kind;
};

// Static description of one instruction.
struct InstrInfo {
    Op op;
    const char *mnemonic;
    const char *asm_format;
    uint32_t opcode;
{%- if not wide %}
    uint64_t mask;        // (word & mask) == match identifies this instruction
    uint64_t match;
{%- endif %}
    Category category;
    const char *exec_type;
    const char *behavior; // source behavior (reference; not executable)
    uint32_t latency;     // cycles, from the uArch (1 if none)
    const OperandInfo *operands;
    uint8_t num_operands;
};

{% for it in instrs %}
{%- if it.operands %}
inline const OperandInfo {{ it.enum }}_operands[] = {
{%- for o in it.operands %}
    { "{{ o.name }}", {{ o.start }}, {{ o.width }}, {{ "true" if o.signed else "false" }}, RegClass::{{ o.rc }}, OperandKind::{{ o.kind }} },
{%- endfor %}
};
{% endif %}
{%- endfor %}

inline const InstrInfo &info(Op op) {
    static const InstrInfo table[] = {
{%- for it in instrs %}
        { Op::{{ it.enum }}, "{{ it.mnemonic }}", "{{ it.asm_format }}", {{ "0x%x" % it.opcode }}, {% if not wide %}{{ "0x%xULL" % it.mask }}, {{ "0x%xULL" % it.match }}, {% endif %}Category::{{ it.category }}, "{{ it.exec_type }}", "{{ it.behavior }}", {{ it.latency }}, {{ (it.enum ~ "_operands") if it.operands else "nullptr" }}, {{ it.operands | length }} },
{%- endfor %}
    };
    for (const auto &e : table)
        if (e.op == op)
            return e;
    static const InstrInfo invalid = { Op::INVALID, "<invalid>", "", 0,{% if not wide %} 0, 0,{% endif %}
                                       Category::none, "", "", 0, nullptr, 0 };
    return invalid;
}

} // namespace {{ ns }}
