#!/usr/bin/env bash
# Generated by ISA-Archive — integrates every generated target in this
# directory into a QEMU source tree (a registry with an `extends:` chain
# generates one target per ISA — base and extension are both handled).
# Usage: bash patch_qemu.sh <path-to-qemu-src>
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QEMU="${1:?Usage: patch_qemu.sh <qemu-src-dir>}"
QEMU="$(realpath "$QEMU")"

ALL_TARGETS=""
for tgt_path in "$SCRIPT_DIR"/target/*/; do
  ISA="$(basename "$tgt_path")"
  ISA_UPPER="$(printf '%s' "$ISA" | tr '[:lower:]-' '[:upper:]_')"
  ALL_TARGETS="${ALL_TARGETS:+$ALL_TARGETS,}${ISA}-softmmu"

  echo "[$ISA 1/4] Copying generated files into QEMU tree..."
  cp -r "$SCRIPT_DIR/target/$ISA/"  "$QEMU/target/$ISA/"
  cp -r "$SCRIPT_DIR/hw/$ISA/"      "$QEMU/hw/$ISA/"
  mkdir -p "$QEMU/configs/targets" "$QEMU/configs/devices/${ISA}-softmmu"
  cp "$SCRIPT_DIR/configs/targets/${ISA}-softmmu.mak"          "$QEMU/configs/targets/"
  cp "$SCRIPT_DIR/configs/devices/${ISA}-softmmu/default.mak"  "$QEMU/configs/devices/${ISA}-softmmu/"

  echo "[$ISA 2/4] Patching target/Kconfig..."
  grep -qF "source ${ISA}/Kconfig" "$QEMU/target/Kconfig" \
    || echo "source ${ISA}/Kconfig" >> "$QEMU/target/Kconfig"

  echo "[$ISA 3/4] Patching target/meson.build, hw/Kconfig, hw/meson.build..."
  grep -qF "subdir('${ISA}')" "$QEMU/target/meson.build" \
    || echo "subdir('${ISA}')" >> "$QEMU/target/meson.build"
  grep -qF "source ${ISA}/Kconfig" "$QEMU/hw/Kconfig" \
    || echo "source ${ISA}/Kconfig" >> "$QEMU/hw/Kconfig"
  grep -qF "subdir('${ISA}')" "$QEMU/hw/meson.build" \
    || echo "subdir('${ISA}')" >> "$QEMU/hw/meson.build"

  echo "[$ISA 4/4] Patching include/sysemu/arch_init.h..."
  ARCH_H="$QEMU/include/sysemu/arch_init.h"
  if grep -qF "QEMU_ARCH_${ISA_UPPER} " "$ARCH_H"; then
    echo "  (already present, skipping)"
  else
    # Find the highest existing bit shift and use the next one (POSIX-compatible)
    NEXT_BIT=$(grep -oE '\(1 << [0-9]+\)' "$ARCH_H" \
                 | sed -E 's/\(1 << ([0-9]+)\)/\1/' \
                 | sort -n | tail -1)
    NEXT_BIT=$(( NEXT_BIT + 1 ))
    # Insert new entry before the closing }; using awk (portable newline handling)
    awk -v entry="    QEMU_ARCH_${ISA_UPPER} = (1 << ${NEXT_BIT})," \
        '/^};/{print entry} 1' "$ARCH_H" > "${ARCH_H}.tmp"
    mv "${ARCH_H}.tmp" "$ARCH_H"
    echo "  Added QEMU_ARCH_${ISA_UPPER} = (1 << ${NEXT_BIT})"
  fi
done

echo ""
echo "Done. To build:"
echo "  cd $QEMU"
echo "  ./configure --target-list=${ALL_TARGETS} --disable-docs --disable-werror"
echo "  ninja -C build"
