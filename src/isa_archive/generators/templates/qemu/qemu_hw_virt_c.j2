/*
 * Generated by ISA-Archive — minimal virtual machine for {{ isa_name }}.
 *
 * Memory map:
 *   0x{{ "%08x" | format(machine.ram_base) }}  RAM ({{ machine.ram_size // (1024 * 1024) }} MiB)  — reset vector 0x{{ "%08x" | format(machine.effective_reset_vector()) }}
{%- for p in (machine.qemu.devices if machine.qemu else []) %}
 *   0x{{ "%08x" | format(p.base) }}  {{ p.name }} ({{ p.type }})
{%- endfor %}
 */

#include "qemu/osdep.h"
#include "qemu/units.h"
#include "qapi/error.h"
#include "hw/boards.h"
#include "hw/loader.h"
#include "exec/address-spaces.h"
#include "cpu.h"
#include "sysemu/sysemu.h"
#include "sysemu/reset.h"
{%- for p in (machine.qemu.devices if machine.qemu else []) %}
{%- if p.type == "ns16550" %}
#include "hw/char/serial-mm.h"
{%- endif %}
{%- if p.type == "sifive_test" %}
#include "hw/misc/sifive_test.h"
{%- endif %}
{%- endfor %}

#define VIRT_RAM_BASE   0x{{ "%08x" | format(machine.ram_base) }}UL
#define VIRT_RAM_SIZE   ({{ machine.ram_size // (1024 * 1024) }} * MiB)
#define VIRT_RESET_VEC  0x{{ "%08x" | format(machine.effective_reset_vector()) }}UL
{%- for p in (machine.qemu.devices if machine.qemu else []) %}
#define VIRT_{{ p.name | upper }}_BASE  0x{{ "%08x" | format(p.base) }}UL
{%- if p.irq is not none %}
#define VIRT_{{ p.name | upper }}_IRQ   {{ p.irq }}
{%- endif %}
{%- endfor %}

{%- if sp_reg_idx is not none %}
/*
 * Pre-initialize the stack pointer to the top of RAM on every reset.
 *
 * This must be a reset handler, not a one-time poke after realize: the system
 * issues a full reset after machine init, and the CPU's reset clears its
 * register state. Registering here means we run *after* that reset, so the
 * stack pointer survives and freestanding C can call functions with no
 * assembly startup code.
 */
static void {{ isa_name | lower | replace("-", "_") }}_cpu_reset(void *opaque)
{
    CPUState *cs = CPU(opaque);
    cpu_reset(cs);
    cpu_env(cs)->{{ sp_reg_file }}[{{ sp_reg_idx }}] = VIRT_RAM_BASE + VIRT_RAM_SIZE;
}
{%- endif %}

static void {{ isa_name | lower | replace("-", "_") }}_virt_init(MachineState *machine)
{
    MemoryRegion *sys = get_system_memory();

    /* CPU */
    Object *cpuobj = object_new(TYPE_{{ isa_name | upper | replace("-", "_") }}_CPU);
    cpu_env(CPU(cpuobj))->resetvec = VIRT_RESET_VEC;
    object_property_set_bool(cpuobj, "realized", true, &error_fatal);
{%- if sp_reg_idx is not none %}
    /* Reset handler sets pc (via cpu_reset) and the stack pointer. */
    qemu_register_reset({{ isa_name | lower | replace("-", "_") }}_cpu_reset, CPU(cpuobj));
{%- else %}
    qemu_register_resettable(cpuobj);
    /* No 'sp' alias declared - no stack pointer to pre-initialize. */
{%- endif %}

    /* RAM */
    memory_region_add_subregion(sys, VIRT_RAM_BASE, machine->ram);
{%- for p in (machine.qemu.devices if machine.qemu else []) %}
{%- if p.type == "ns16550" %}

    /* {{ p.name }} NS16550 UART */
    serial_mm_init(sys, VIRT_{{ p.name | upper }}_BASE, 0, NULL, 115200,
                   serial_hd(0), DEVICE_LITTLE_ENDIAN);
{%- elif p.type == "sifive_test" %}

    /* {{ p.name }} SiFive test device (write 0x5555 = exit 0) */
    sifive_test_create(VIRT_{{ p.name | upper }}_BASE);
{%- endif %}
{%- endfor %}

    /* Load kernel ELF */
    if (machine->kernel_filename) {
        load_elf_ram_sym(machine->kernel_filename, NULL, NULL, NULL,
                         NULL, NULL, NULL, NULL,
                         0, 0, 1, 0, NULL, false, NULL);
    }
}

static void {{ isa_name | lower | replace("-", "_") }}_virt_machine_init(MachineClass *mc)
{
    mc->desc             = "ISA-Archive {{ isa_name }} virtual machine";
    mc->init             = {{ isa_name | lower | replace("-", "_") }}_virt_init;
    mc->default_cpu_type = TYPE_{{ isa_name | upper | replace("-", "_") }}_CPU;
    mc->default_ram_size = VIRT_RAM_SIZE;
    mc->default_ram_id   = "{{ isa_name | lower }}.ram";
}

DEFINE_MACHINE("{{ isa_name | lower }}-virt", {{ isa_name | lower | replace("-", "_") }}_virt_machine_init)
