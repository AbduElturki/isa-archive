{% import "_macros.j2" as m %}{{ m.file_header('c', isa_name) }}
#include "qemu/osdep.h"
#include "{{ isa_name }}_arch.h"
#include "tcg/tcg.h"
#include "tcg/tcg-op.h"
#include "exec/helper-gen.h"

TCGv_{{ tcg_type }} arch_pc;
{% for reg in isa_reg.registers %}
{%- set st = reg_storage[reg.name] %}
{%- if st.tcg %}
TCGv_{{ st.tcg }} arch_{{ reg.name }}[{{ reg.count }}];   /* {{ reg.width }}-bit */
{%- else %}
/* {{ reg.name }} ({{ reg.width }}-bit): no TCG global — helper-only access via env-> */
{%- endif %}
{% endfor %}
{%- for csr in isa_reg.arch_csrs %}
TCGv_{{ tcg_type }} arch_{{ csr.name }};
{%- endfor %}

/* INTEGRATION: Call {{ isa_name | lower | replace("-", "_") }}_translate_init() once from arch_init() to initialize TCG globals */
void {{ isa_name | lower | replace("-", "_") }}_translate_init(void) {
    arch_pc = tcg_global_mem_new_{{ tcg_type }}(tcg_env, offsetof(ArchState, pc), "pc");
{%- for reg in isa_reg.registers %}
{%- set st = reg_storage[reg.name] %}
{%- if st.tcg %}
    for (int i = 0; i < {{ reg.count }}; i++) {
        char _{{ reg.name }}_name[32];
        snprintf(_{{ reg.name }}_name, sizeof(_{{ reg.name }}_name), "{{ reg.name }}_%d", i);
        arch_{{ reg.name }}[i] = tcg_global_mem_new_{{ st.tcg }}(tcg_env,
            offsetof(ArchState, {{ reg.name }}[i]),
            _{{ reg.name }}_name);
    }
{%- endif %}
{%- endfor %}
{%- for csr in isa_reg.arch_csrs %}
    arch_{{ csr.name }} = tcg_global_mem_new_{{ tcg_type }}(tcg_env,
        offsetof(ArchState, {{ csr.name }}), "{{ csr.name }}");
{%- endfor %}
}

{% for instr in instructions.values() %}
{%- set info = instr | qemu_info(isa_reg) -%}
{%- set fn = instr.metadata.name | lower | replace("-", "_") %}
/* {{ instr.metadata.name }}{% if instr.spec.description %}: {{ instr.spec.description }}{% endif %}
 * Lowered {% if info.tcg_code %}inline with native TCG ops{% else %}via the {{ fn }} helper{% endif %}. */
static bool trans_{{ fn }}(DisasContext *ctx, arg_{{ fn }} *a) {
{%- if not info.modifies_pc %}
{%- for g in info.zero_guards %}
    if (a->{{ g.field }} == {{ g.index }}) return true;   /* writes are dropped for the zero register */
{%- endfor %}
{%- endif %}
{%- for c in info.constraints %}
    if (!({{ c.c_expr }})) {
        /* Constraint violated → treat as illegal (decode falls through). */
        qemu_log_mask(LOG_GUEST_ERROR, "{{ instr.metadata.name }}: {{ c.message }}\n");
        return false;
    }
{%- endfor %}
{%- if info.tcg_code %}
    {{ info.tcg_code | indent(4) }}
{%- else %}
{%- if info.modifies_pc or info.reads_pc %}
    /* Set env->pc to this instruction's PC before the helper runs; pc_next was
       already advanced by translate_insn, so subtract the instruction size. */
    tcg_gen_movi_{{ tcg_type }}(arch_pc, (uint{{ tcg_bits }}_t)(ctx->base.pc_next - {{ info.bytes_per_instr }}){% if xlen_mask %} & {{ xlen_mask }}{% endif %});
{%- endif %}
    gen_helper_{{ fn }}(tcg_env{% for arg in info.tcg_args %}, {{ arg.tcg }}{% endfor %});
{%- endif %}
{%- if info.is_unconditional_jump %}
    ctx->base.is_jmp = DISAS_NORETURN;
{%- elif info.is_conditional_branch %}
    ctx->base.is_jmp = DISAS_TARGET_0;
{%- endif %}
    return true;
}
{% endfor %}
