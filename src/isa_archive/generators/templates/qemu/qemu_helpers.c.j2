{% import "_macros.j2" as m %}{{ m.file_header('c', isa_name) }}
#include "qemu/osdep.h"
#include "{{ isa_name }}_arch.h"
#include "exec/exec-all.h"
#include "exec/helper-proto.h"
{%- if has_mem %}
#include "exec/cpu_ldst.h"
{%- endif %}
{%- if has_float %}
#include <string.h>
{%- endif %}
{%- for inc in c_includes %}
#include {{ inc }}
{%- endfor %}
{%- if isa_reg.operands %}
#include "{{ isa_name }}_operands.h"
{%- endif %}

{% if has_sext %}
/* Sign-extend the low `bits` of a value (PC-relative offsets, split immediates). */
static inline int32_t isa_sext32(uint32_t v, unsigned bits) {
    return (int32_t)(v << (32 - bits)) >> (32 - bits);
}
static inline int64_t isa_sext64(uint64_t v, unsigned bits) {
    return (int64_t)(v << (64 - bits)) >> (64 - bits);
}
{% endif %}
{% if float_scalar_types %}
/* Floating-point bit reinterpretation (registers store raw bits). */
{%- for ft in float_scalar_types %}
{%- set w = ft.w %}
{%- if ft.c_type %}
static inline {{ ft.c_type }} u2f{{ w }}(uint{{ w }}_t b){ {{ ft.c_type }} f; memcpy(&f, &b, {{ w // 8 }}); return f; }
static inline uint{{ w }}_t f2u{{ w }}({{ ft.c_type }} f){ uint{{ w }}_t b; memcpy(&b, &f, {{ w // 8 }}); return b; }
{%- endif %}
{%- endfor %}
{% endif %}

G_NORETURN void HELPER(raise_exception)(CPUArchState *env, uint32_t excp)
{
    CPUState *cs = env_cpu(env);
    cs->exception_index = excp;
    cpu_loop_exit(cs);
}

{% for instr in instructions.values() %}
{%- set info = instr | qemu_info(isa_reg) -%}
/**
 * {{ instr.metadata.name }}{% if instr.spec.description %}: {{ instr.spec.description }}{% endif %}
 */
void HELPER({{ instr.metadata.name | lower | replace("-", "_") }})(CPUArchState *env{% for arg in info.helper_args %}, {{ arg.type }} {{ arg.name }}{% endfor %}) {
{%- if not info.modifies_pc %}
{%- for g in info.zero_guards %}
    if ({{ g.field }} == {{ g.index }}) return;
{%- endfor %}
{%- endif %}
{%- if info.is_conditional_branch %}
    int _branch_taken = 0;
    {{ info.code | indent(4) }}
    if (!_branch_taken) env->pc = (env->pc + {{ info.bytes_per_instr }}){% if xlen_mask %} & {{ xlen_mask }}{% endif %};
{%- else %}
    {{ info.code | indent(4) }}
{%- endif %}
}
{% endfor %}
