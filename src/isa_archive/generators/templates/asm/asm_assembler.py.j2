#!/usr/bin/env python3
"""
{{ isa_name }} Assembler — generated by isa-archive
Usage:
  python {{ isa_name }}_asm.py input.s [-o output.bin]
  python {{ isa_name }}_asm.py input.s [-o output.elf] --elf
"""

import sys
import re
import struct
import argparse

# ── Constants ──────────────────────────────────────────────────────────────────
XLEN        = {{ xlen }}
LOAD_ADDR   = {{ "0x%08x" | format(machine.ram_base) }}
ENTRY_ADDR  = {{ "0x%08x" | format(machine.effective_reset_vector()) }}

# ── Register table ─────────────────────────────────────────────────────────────
REGS = {
{% for reg in registers %}
{%- for i in range(reg.count) %}
    "{{ reg.prefix }}{{ i }}": {{ i }},
{% endfor %}
{%- for alias, num in reg.aliases.items() %}
    "{{ alias }}": {{ num }},
{% endfor %}
{% endfor %}
}

# ── Instruction encoders ───────────────────────────────────────────────────────
{% for instr in instr_infos %}
def _enc_{{ instr.name }}({{ instr.param_list }}):
    word = {{ instr.fixed_hex }}
{%   for rf in instr.reg_fields %}
    word |= ({{ rf.name }} & 0x{{ "%x" | format(rf.mask) }}) << {{ rf.start }}
{%   endfor %}
{%   if instr.has_imm %}
    _imm = imm & {{ instr.imm_mask }}
{%     for sf in instr.imm_subfields %}
    word |= ((_imm >> {{ sf.low }}) & 0x{{ "%x" | format(sf.mask) }}) << {{ sf.start }}  # {{ sf.name }}[{{ sf.high }}:{{ sf.low }}]
{%     endfor %}
{%   endif %}
    return {% if instr.bytes == 4 %}struct.pack("<I", word){% else %}word.to_bytes({{ instr.bytes }}, "little"){% endif %}

{% endfor %}
# ── Dispatch table ─────────────────────────────────────────────────────────────
# Maps MNEMONIC → (asm_operand_spec, encoder_fn)
# Operand spec tokens:
#   "r:name"       — register operand stored as `name`
#   "i:name"       — immediate integer
#   "l:name"       — label-or-integer, converted to PC-relative offset
#   "m:off:base"   — memory syntax: imm(reg), stored as `off` and `base`
INSTRS = {
{% for instr in instr_infos %}
    "{{ instr.name }}": ({{ instr.asm_operands }}, _enc_{{ instr.name }}),
{% endfor %}
}

# ── Helpers ────────────────────────────────────────────────────────────────────

class AsmError(Exception):
    def __init__(self, msg, lineno=None):
        self.lineno = lineno
        super().__init__(f"line {lineno}: {msg}" if lineno else msg)


def _parse_reg(token):
    token = token.strip()
    if token in REGS:
        return REGS[token]
    raise AsmError(f"Unknown register: {token!r}")


def _parse_int(token):
    token = token.strip()
    try:
        return int(token, 0)
    except ValueError:
        raise AsmError(f"Invalid integer: {token!r}")


def _resolve_target(token, labels, current_addr):
    """Parse a label name or integer literal, returning the absolute address."""
    token = token.strip()
    # Simple label±offset: "label", "label+4", "label-8"
    m = re.match(r'^(\w+)\s*([+-]\s*\d+)?$', token)
    if m:
        name = m.group(1)
        if name in labels:
            base = labels[name]
            offset = int(m.group(2).replace(" ", ""), 0) if m.group(2) else 0
            return base + offset
        # Might be a plain integer
        try:
            return int(name, 0)
        except ValueError:
            raise AsmError(f"Undefined label: {name!r}")
    return _parse_int(token)


def _split_operands(s):
    """Split operand string by commas, respecting parentheses."""
    parts = []
    depth = 0
    cur = []
    for ch in s:
        if ch == '(':
            depth += 1
            cur.append(ch)
        elif ch == ')':
            depth -= 1
            cur.append(ch)
        elif ch == ',' and depth == 0:
            parts.append(''.join(cur).strip())
            cur = []
        else:
            cur.append(ch)
    if cur:
        parts.append(''.join(cur).strip())
    return parts


def _encode_instr(name, operands_str, labels, addr):
    """Encode one instruction, resolving labels. Returns bytes."""
    if name not in INSTRS:
        raise AsmError(f"Unknown instruction: {name!r}")
    spec, enc_fn = INSTRS[name]
    parts = _split_operands(operands_str) if operands_str else []
    kwargs = {}
    part_idx = 0
    for tok in spec:
        kind, *rest = tok.split(":")
        if kind == "r":
            if part_idx >= len(parts):
                raise AsmError(f"{name}: missing register operand #{part_idx + 1}")
            kwargs[rest[0]] = _parse_reg(parts[part_idx])
            part_idx += 1
        elif kind == "i":
            if part_idx >= len(parts):
                raise AsmError(f"{name}: missing immediate operand")
            kwargs[rest[0]] = _parse_int(parts[part_idx])
            part_idx += 1
        elif kind == "l":
            if part_idx >= len(parts):
                raise AsmError(f"{name}: missing label/offset operand")
            target = _resolve_target(parts[part_idx], labels, addr)
            kwargs[rest[0]] = target - addr  # PC-relative
            part_idx += 1
        elif kind == "m":
            # imm(reg) syntax
            if part_idx >= len(parts):
                raise AsmError(f"{name}: missing mem operand")
            raw = parts[part_idx].strip()
            m = re.match(r'^(.*)\((\w+)\)$', raw)
            if m:
                kwargs[rest[0]] = _parse_int(m.group(1))
                kwargs[rest[1]] = _parse_reg(m.group(2))
            else:
                # Allow bare immediate with next part as base: "0, x1"
                kwargs[rest[0]] = _parse_int(raw)
                part_idx += 1
                if part_idx >= len(parts):
                    raise AsmError(f"{name}: missing base register for memory operand")
                kwargs[rest[1]] = _parse_reg(parts[part_idx])
            part_idx += 1
    return enc_fn(**kwargs)


# ── Two-pass assembler ─────────────────────────────────────────────────────────

class Section:
    def __init__(self, name, load_offset=0):
        self.name = name
        self.data = bytearray()
        self.load_offset = load_offset  # byte offset from LOAD_ADDR

    def size(self):
        return len(self.data)


def _strip_comment(line):
    """Remove // and # comments, respect strings."""
    for m in re.finditer(r'(//|#)', line):
        line = line[:m.start()]
        break
    return line.strip()


def assemble(source: str, base_addr: int = None) -> bytes:
    if base_addr is None:
        base_addr = ENTRY_ADDR

    lines = source.splitlines()

    # ── Pass 1: layout ────────────────────────────────────────────────────────
    labels = {}
    items = []   # list of (lineno, type, payload)
    # type: "label", "instr", "data", "align", "section", "skip"

    current_addr = base_addr

    for lineno, raw in enumerate(lines, 1):
        line = _strip_comment(raw)
        if not line:
            continue

        # Label: may prefix an instruction on the same line
        while True:
            m = re.match(r'^(\w+):\s*(.*)', line)
            if m:
                lbl = m.group(1)
                labels[lbl] = current_addr
                items.append((lineno, "label", lbl))
                line = m.group(2).strip()
            else:
                break
        if not line:
            continue

        if line.startswith('.'):
            parts = line.split(None, 1)
            directive = parts[0].lower()
            rest = parts[1].strip() if len(parts) > 1 else ""

            if directive in ('.text', '.data', '.bss', '.rodata', '.section'):
                items.append((lineno, "section", directive))
            elif directive in ('.global', '.globl', '.local', '.type', '.size', '.file', '.ident'):
                pass  # ignored for flat binary
            elif directive == '.align':
                n = _parse_int(rest) if rest else 2
                align_bytes = 1 << n if n <= 12 else n  # .align N means 2^N bytes
                pad = (-current_addr) % align_bytes
                current_addr += pad
                items.append((lineno, "align", (align_bytes, pad)))
            elif directive == '.balign':
                n = _parse_int(rest)
                pad = (-current_addr) % n
                current_addr += pad
                items.append((lineno, "align", (n, pad)))
            elif directive in ('.byte', '.8bit'):
                vals = [v.strip() for v in rest.split(',')]
                current_addr += len(vals)
                items.append((lineno, "data", (1, vals)))
            elif directive in ('.half', '.short', '.2byte'):
                vals = [v.strip() for v in rest.split(',')]
                current_addr += 2 * len(vals)
                items.append((lineno, "data", (2, vals)))
            elif directive in ('.word', '.long', '.4byte'):
                vals = [v.strip() for v in rest.split(',')]
                current_addr += 4 * len(vals)
                items.append((lineno, "data", (4, vals)))
            elif directive in ('.dword', '.8byte', '.quad'):
                vals = [v.strip() for v in rest.split(',')]
                current_addr += 8 * len(vals)
                items.append((lineno, "data", (8, vals)))
            elif directive in ('.ascii', '.string', '.asciz'):
                s = _parse_string(rest)
                if directive in ('.string', '.asciz'):
                    s += b'\x00'
                current_addr += len(s)
                items.append((lineno, "bytes", s))
            elif directive == '.zero':
                n = _parse_int(rest)
                current_addr += n
                items.append((lineno, "bytes", bytes(n)))
            elif directive == '.skip':
                n = _parse_int(rest.split(',')[0])
                current_addr += n
                items.append((lineno, "bytes", bytes(n)))
            else:
                pass  # unknown directive — skip
        else:
            parts = line.split(None, 1)
            mnemonic = parts[0].upper()
            operands_str = parts[1].strip() if len(parts) > 1 else ""

            if mnemonic in INSTRS:
                current_addr += 4  # all instructions are fixed-width
                items.append((lineno, "instr", (mnemonic, operands_str)))
            else:
                raise AsmError(f"Unknown mnemonic: {mnemonic!r}", lineno)

    # ── Pass 2: encode ────────────────────────────────────────────────────────
    output = bytearray()
    current_addr = base_addr

    for lineno, kind, payload in items:
        try:
            if kind == "label":
                pass
            elif kind == "section":
                pass
            elif kind == "align":
                align_bytes, _ = payload
                pad = (-current_addr) % align_bytes
                output += bytes(pad)
                current_addr += pad
            elif kind == "data":
                width, vals = payload
                for v in vals:
                    try:
                        n = int(v, 0)
                    except ValueError:
                        n = _resolve_target(v, labels, current_addr)
                    output += n.to_bytes(width, "little", signed=(n < 0))
                    current_addr += width
            elif kind == "bytes":
                output += payload
                current_addr += len(payload)
            elif kind == "instr":
                mnemonic, operands_str = payload
                enc = _encode_instr(mnemonic, operands_str, labels, current_addr)
                output += enc
                current_addr += len(enc)
        except AsmError as e:
            e.lineno = e.lineno or lineno
            raise

    return bytes(output)


def _parse_string(s):
    """Parse a quoted string literal → bytes."""
    s = s.strip()
    if s.startswith('"') and s.endswith('"'):
        s = s[1:-1]
    result = bytearray()
    i = 0
    while i < len(s):
        if s[i] == '\\':
            i += 1
            esc = {'n': 10, 'r': 13, 't': 9, '0': 0, '\\': 92, '"': 34, "'": 39}
            result.append(esc.get(s[i], ord(s[i])))
        else:
            result.append(ord(s[i]))
        i += 1
    return bytes(result)


# ── Minimal ELF32 writer ───────────────────────────────────────────────────────

def _write_elf32(code: bytes, load_addr: int, entry_addr: int, e_machine: int = 243) -> bytes:
    """Pack code into a minimal ELF32 executable (one PT_LOAD segment)."""
    ELFMAG        = b'\x7fELF'
    ELFCLASS32    = 1
    ELFDATA2LSB   = 1
    ET_EXEC       = 2
    PT_LOAD       = 1
    PF_R, PF_X    = 4, 1

    code_offset = 52 + 32  # ELF header + one program header

    e_ident = (ELFMAG + bytes([ELFCLASS32, ELFDATA2LSB, 1, 0]) + b'\x00' * 8)
    ehdr = struct.pack('<2HI3IIHHHHHH',
        ET_EXEC, e_machine, 1,
        entry_addr,          # e_entry
        52,                  # e_phoff
        0,                   # e_shoff
        0,                   # e_flags
        52,                  # e_ehsize
        32,                  # e_phentsize
        1,                   # e_phnum
        40, 0, 0,            # e_shentsize, e_shnum, e_shstrndx
    )

    phdr = struct.pack('<8I',
        PT_LOAD,
        code_offset,
        load_addr,
        load_addr,
        len(code),
        len(code),
        PF_R | PF_X,
        0x1000,              # p_align
    )

    return e_ident + ehdr + phdr + code


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    ap = argparse.ArgumentParser(description="{{ isa_name }} assembler")
    ap.add_argument("input", help="Assembly source file (.s)")
    ap.add_argument("-o", "--output", default=None,
                    help="Output file (default: input stem + .bin or .elf)")
    ap.add_argument("--elf", action="store_true",
                    help="Emit ELF32 executable instead of flat binary")
    ap.add_argument("--base", default=None,
                    help=f"Load/entry address in hex (default: 0x{ENTRY_ADDR:08x})")
    args = ap.parse_args()

    base_addr = int(args.base, 0) if args.base else ENTRY_ADDR

    try:
        with open(args.input) as f:
            source = f.read()
    except FileNotFoundError:
        sys.exit(f"Error: file not found: {args.input}")

    try:
        code = assemble(source, base_addr=base_addr)
    except AsmError as e:
        sys.exit(f"Assembler error: {e}")

    if args.output is None:
        stem = args.input.rsplit(".", 1)[0] if "." in args.input else args.input
        args.output = stem + (".elf" if args.elf else ".bin")

    if args.elf:
        data = _write_elf32(code, load_addr=base_addr, entry_addr=base_addr)
    else:
        data = code

    with open(args.output, "wb") as f:
        f.write(data)

    print(f"Written {len(data)} bytes → {args.output}")


if __name__ == "__main__":
    main()
