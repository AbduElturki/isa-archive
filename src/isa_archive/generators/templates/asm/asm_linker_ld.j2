/* {{ isa_name }} linker script — generated by isa-archive */

OUTPUT_ARCH(riscv)
ENTRY(_start)

MEMORY {
    RAM (rwx) : ORIGIN = {{ "0x%08x" | format(machine.ram_base) }}, LENGTH = {{ machine.ram_size }}
}

SECTIONS {
    . = {{ "0x%08x" | format(machine.effective_reset_vector()) }};

    .text : {
        *(.text.init)
        *(.text*)
    } > RAM

    .rodata : {
        *(.rodata*)
    } > RAM

    .data : {
        *(.data*)
    } > RAM

    .bss : {
        _bss_start = .;
        *(.bss*)
        *(COMMON)
        _bss_end = .;
    } > RAM

    _stack_top = ORIGIN(RAM) + LENGTH(RAM);
}
