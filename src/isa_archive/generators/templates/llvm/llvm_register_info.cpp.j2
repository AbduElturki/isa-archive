bool {{ ISA }}RegisterInfo::eliminateFrameIndex(MachineBasicBlock::iterator MI,
                                                int SPAdj, unsigned FIOperandNum,
                                                RegScavenger *RS) const {
  // Frame-index elimination: the frame-index operand is the *base register* of a
  // load/store. Replace it with the stack pointer and fold the slot offset into
  // the instruction's immediate-offset operand.
  MachineInstr &MIi = *MI;
  MachineFunction &MF = *MIi.getMF();
  const MachineFrameInfo &MFI = MF.getFrameInfo();
  int FrameIndex = MIi.getOperand(FIOperandNum).getIndex();
  // SP-relative offset: object offset (from the CFA) + the prologue's stack size.
  int64_t Offset = MFI.getObjectOffset(FrameIndex) + (int64_t)MFI.getStackSize() + SPAdj;
{% if sp_reg %}
  MIi.getOperand(FIOperandNum).ChangeToRegister({{ ISA }}::{{ sp_reg }}, /*isDef=*/false);
{% else %}
  report_fatal_error("{{ isa_name }}: frame-index elimination needs a stack-pointer register");
{% endif %}
  // Add the offset to the instruction's immediate operand (the addressing offset).
  for (unsigned i = 0, e = MIi.getNumOperands(); i != e; ++i) {
    if (i != FIOperandNum && MIi.getOperand(i).isImm()) {
      MIi.getOperand(i).setImm(MIi.getOperand(i).getImm() + Offset);
      break;
    }
  }
  return false;
}

