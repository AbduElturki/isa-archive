// {{ isa_name }} Calling convention — generated by isa-archive

// Return value convention
def RetCC_{{ ISA }} : CallingConv<[
{% if abi_fp_ret_regs and float_value_types %}
  CCIfType<[{{ float_value_types | join(', ') }}], CCAssignToReg<[{{ abi_fp_ret_regs | join(', ') }}]>>,
{% endif %}
{% for reg in abi_ret_regs %}
  CCIfType<[i{{ xlen }}], CCAssignToReg<[{{ reg }}]>>,
{% endfor %}
  CCAssignToStack<{{ xlen // 8 }}, {{ xlen // 8 }}>
]>;

// Argument passing convention
def CC_{{ ISA }} : CallingConv<[
{% if abi_fp_arg_regs and float_value_types %}
  CCIfType<[{{ float_value_types | join(', ') }}], CCAssignToReg<[{{ abi_fp_arg_regs | join(', ') }}]>>,
{% endif %}
{% for reg in abi_arg_regs %}
  CCIfType<[i{{ xlen }}], CCAssignToReg<[{{ reg }}]>>,
{% endfor %}
  CCAssignToStack<{{ xlen // 8 }}, {{ xlen // 8 }}>
]>;

// Callee-saved registers
def CSR_{{ ISA }} : CalleeSavedRegs<(add
  {{ abi_saved_regs | join(', ') }}
)>;
