  if ({{ ISA }}::{{ first_reg_class }}RegClass.contains(DstReg, SrcReg)) {
    // No add-immediate: copy as ADD DstReg, SrcReg, zero.
    BuildMI(MBB, MBBI, DL, get({{ ISA }}::{{ compiler_roles.get("alu_rr.add") }}), DstReg)
        .addReg(SrcReg, getKillRegState(KillSrc))
        .addReg({{ ISA }}::{{ zero_reg }});
