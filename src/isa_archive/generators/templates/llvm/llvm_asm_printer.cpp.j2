void {{ ISA }}AsmPrinter::emitInstruction(const MachineInstr *MI) {
  // Try expanding a pseudo to its real instruction first.
  if (emitPseudoExpansionLowering(*OutStreamer, MI))
    return;
  MCInst TmpInst;
  lowerToMCInst(MI, TmpInst);
  EmitToStreamer(*OutStreamer, TmpInst);
}

