// {{ isa_name }} Instruction formats — generated by isa-archive
// Derived from ISA Schema definitions.

class {{ ISA }}Inst<dag outs, dag ins, string asmstr, list<dag> pattern,
                   InstrItinClass itin = NoItinerary>
    : Instruction {
  field bits<{{ insn_bits }}> Inst;
  let Namespace  = "{{ ISA }}";
  let Size       = {{ insn_bytes }};
  let OutOperandList = outs;
  let InOperandList  = ins;
  let AsmString      = asmstr;
  let Pattern        = pattern;
  let Itinerary      = itin;
}

{% for schema_name, schema in schemas.items() %}
{%- set cimm = schema_combined_imm[schema_name] %}
// Schema: {{ schema_name }} ({{ schema.spec.length }}-bit)
class {{ ISA }}_{{ schema_name }}<dag outs, dag ins, string asmstr, list<dag> pattern>
    : {{ ISA }}Inst<outs, ins, asmstr, pattern> {
{% if cimm %}
  // Combined logical immediate ({{ cimm.width }}-bit) with hardware-scrambled bit routing
  bits<{{ cimm.width }}> imm;
{% for hw_high, hw_low, imm_high, imm_low in cimm.hw_assignments %}
{%- if hw_high == hw_low %}
  let Inst{{"{"}}{{ hw_high }}{{"}"}} = imm{{"{"}}{{ imm_high }}{{ "}" }};
{%- else %}
  let Inst{{"{"}}{{ hw_high }}-{{ hw_low }}{{"}"}} = imm{{"{"}}{{ imm_high }}-{{ imm_low }}{{ "}" }};
{%- endif %}
{% endfor %}
{% endif %}
{% for field in schema.spec.fields %}
{%- if field.role.name == "IMMEDIATE" and cimm %}
{%- else %}
  bits<{{ field.width }}> {{ field.name }};
  let Inst{{"{"}}{{ field.start + field.width - 1 }}{{ "-" if field.width > 1 else "" }}{{ field.start if field.width > 1 else "" }}{{"}"}} = {{ field.name }};
{% endif %}
{% endfor %}
}

{% endfor %}
