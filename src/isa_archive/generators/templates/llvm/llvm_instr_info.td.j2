// {{ isa_name }} Instruction definitions — generated by isa-archive

// ── Target-specific SDNode types ─────────────────────────────────────────────

{% if has_global_addr %}
def SDT_{{ ISA }}Hi : SDTypeProfile<1, 1, [SDTCisSameAs<0, 1>, SDTCisVT<0, i{{ xlen }}>]>;
def {{ ISA }}ISD_HI : SDNode<"{{ ISA }}ISD::HI", SDT_{{ ISA }}Hi>;
def {{ ISA }}ISD_LO : SDNode<"{{ ISA }}ISD::LO", SDT_{{ ISA }}Hi>;
{% endif %}
{% if has_select %}
// (SELECTCC cond, tval, fval) → result; expanded to a branch diamond by the inserter.
def SDT_{{ ISA }}SelectCC : SDTypeProfile<1, 3,
    [SDTCisVT<0, i{{ xlen }}>, SDTCisVT<1, i{{ xlen }}>,
     SDTCisSameAs<0, 2>, SDTCisSameAs<0, 3>]>;
def {{ ISA }}ISD_SELECTCC : SDNode<"{{ ISA }}ISD::SELECTCC", SDT_{{ ISA }}SelectCC>;
{% endif %}

// ── Immediate operand types ────────────────────────────────────────────────

{% for op in imm_operands %}
def {{ op.name }} : Operand<i{{ xlen }}>,
    ImmLeaf<i{{ xlen }}, [{ return {% if op.sign == "s" %}isInt{% else %}isUInt{% endif %}<{{ op.width }}>(Imm); }]> {
  let DecoderMethod = "decode{{ op.sign | upper }}Imm{{ op.width }}";
}
{% endfor %}

// ── Branch/jump target operand ─────────────────────────────────────────────

def brtarget : Operand<OtherVT> {
  let PrintMethod = "printBranchTarget";
}
def jaltarget : Operand<OtherVT> {
  let PrintMethod = "printJalTarget";
}

// ── Instruction definitions ────────────────────────────────────────────────

{% for instr_name, instr_info in instr_defs %}
// {{ instr_name }}{% if instr_info.description %}: {{ instr_info.description }}{% endif %}

{% set schema = instr_info.schema %}
{% set is_handled_branch = instr_info.dag_category == "branch" and instr_info.branch_cond %}
{% if instr_info.dag_pattern %}
def {{ instr_name }} : {{ ISA }}_{{ schema }}<
    (outs {{ instr_info.outs }}),
    (ins  {{ instr_info.ins }}),
    "{{ instr_name | lower }}\t{{ instr_info.asm_str }}",
    [{{ instr_info.dag_pattern }}]
> {
  let isTerminator = {{ "1" if instr_info.is_terminator else "0" }};
  let isBranch     = {{ "1" if instr_info.dag_category in ("jump_abs", "jump_ind") else ("1" if instr_info.is_branch else "0") }};
  let isBarrier    = {{ "1" if instr_info.dag_category in ("jump_abs", "jump_ind") else "0" }};
  let isCall       = {{ "1" if instr_info.is_call else "0" }};
  let isReturn     = {{ "1" if instr_info.is_return else "0" }};
{% for field_name, field_val in instr_info.fixed_fields.items() %}
  let {{ field_name }} = {{ field_val }};
{% endfor %}
}
{% elif is_handled_branch %}
def {{ instr_name }} : {{ ISA }}_{{ schema }}<
    (outs {{ instr_info.outs }}),
    (ins  {{ instr_info.ins }}),
    "{{ instr_name | lower }}\t{{ instr_info.asm_str }}",
    []
> {
  let isTerminator = 1;
  let isBranch     = 1;
  let isCall       = 0;
  let isReturn     = 0;
{% for field_name, field_val in instr_info.fixed_fields.items() %}
  let {{ field_name }} = {{ field_val }};
{% endfor %}
}
{% else %}
def {{ instr_name }} : {{ ISA }}_{{ schema }}<
    (outs {{ instr_info.outs }}),
    (ins  {{ instr_info.ins }}),
    "{{ instr_name | lower }}\t{{ instr_info.asm_str }}",
    []
> {
  let isTerminator = {{ "1" if instr_info.is_terminator else "0" }};
  let isBranch     = {{ "1" if instr_info.dag_category in ("jump_abs", "jump_ind") else ("1" if instr_info.is_branch else "0") }};
  let isBarrier    = {{ "1" if instr_info.dag_category in ("jump_abs", "jump_ind") else "0" }};
  let isCall       = {{ "1" if instr_info.is_call else "0" }};
  let isReturn     = {{ "1" if instr_info.is_return else "0" }};
{% for field_name, field_val in instr_info.fixed_fields.items() %}
  let {{ field_name }} = {{ field_val }};
{% endfor %}
}
{% endif %}

{% endfor %}

// ── Conditional branch Pat<> patterns ────────────────────────────────────────
{% for instr_name, instr_info in instr_defs %}
{% if instr_info.dag_category == "branch" and instr_info.branch_cond %}
def : Pat<(brcond (i{{ xlen }} ({{ instr_info.branch_cond }} i{{ xlen }}:$rs1, i{{ xlen }}:$rs2)), bb:$target),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ first_reg_class }}:$rs2, brtarget:$target)>;
{% endif %}
{% endfor %}

// ── Zero-offset memory fallback Pat<> patterns ────────────────────────────────
// Match loads/stores where the address is a bare register (offset = 0 implied).
// Indexed (base+register) loads/stores are matched by their inline def pattern.
{% for instr_name, instr_info in instr_defs %}
{% set w = instr_info.dag_load_width %}
{% if instr_info.dag_category == "store" and w and not instr_info.dag_is_float and not instr_info.dag_addr_indexed %}
{% set store_op = "store" if w == xlen else "truncstorei" + w|string %}
def : Pat<({{ store_op }} {{ first_reg_class }}:$rs2, {{ first_reg_class }}:$rs1),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ first_reg_class }}:$rs2, 0)>;
{% endif %}
{% if instr_info.dag_category == "load" and w and not instr_info.dag_is_float and not instr_info.dag_addr_indexed %}
{% set load_op = "load" if w == xlen else (("sextloadi" + w|string) if instr_info.dag_load_signed else ("zextloadi" + w|string)) %}
def : Pat<({{ load_op }} {{ first_reg_class }}:$rs1),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, 0)>;
{% if w < xlen %}
def : Pat<(extloadi{{ w }} {{ first_reg_class }}:$rs1),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, 0)>;
{% endif %}
{% endif %}
{% endfor %}

// ── Register+offset memory Pat<> patterns ─────────────────────────────────────
// Match loads/stores where the address is (base_reg + simm12_offset).
{% for instr_name, instr_info in instr_defs %}
{% set w = instr_info.dag_load_width %}
{% if instr_info.dag_category == "store" and w and not instr_info.dag_is_float and not instr_info.dag_addr_indexed and imm_operands %}
{% set store_op = "store" if w == xlen else "truncstorei" + w|string %}
def : Pat<({{ store_op }} {{ first_reg_class }}:$rs2, (add {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ first_reg_class }}:$rs2, {{ imm_operands[0].name }}:$imm)>;
{% endif %}
{% if instr_info.dag_category == "load" and w and not instr_info.dag_is_float and not instr_info.dag_addr_indexed and imm_operands %}
{% set load_op = "load" if w == xlen else (("sextloadi" + w|string) if instr_info.dag_load_signed else ("zextloadi" + w|string)) %}
def : Pat<({{ load_op }} (add {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)>;
{% if w < xlen %}
def : Pat<(extloadi{{ w }} (add {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)>;
{% endif %}
{% endif %}
{% endfor %}

{% if fp_reg_class %}
// ── Floating-point load/store Pat<> patterns (typed f32/f64 loads & stores) ───
{% for instr_name, instr_info in instr_defs %}
{% set w = instr_info.dag_load_width %}
{% if instr_info.dag_category == "load" and w and instr_info.dag_is_float %}
def : Pat<(f{{ w }} (load {{ first_reg_class }}:$rs1)),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, 0)>;
def : Pat<(f{{ w }} (load (add {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm))),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)>;
{% endif %}
{% if instr_info.dag_category == "store" and w and instr_info.dag_is_float %}
def : Pat<(store (f{{ w }} {{ fp_reg_class }}:$rs2), {{ first_reg_class }}:$rs1),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ fp_reg_class }}:$rs2, 0)>;
def : Pat<(store (f{{ w }} {{ fp_reg_class }}:$rs2), (add {{ first_reg_class }}:$rs1, {{ imm_operands[0].name }}:$imm)),
          ({{ instr_name }} {{ first_reg_class }}:$rs1, {{ fp_reg_class }}:$rs2, {{ imm_operands[0].name }}:$imm)>;
{% endif %}
{% endfor %}
{% endif %}

{% if has_global_addr %}
// ── Global address ({{ lui_opcode }}+{{ addi_opcode }}) patterns ─────────────────────────────────────
// HI(sym)+LO(sym) = {{ xlen }}-bit address via {{ lui_opcode }}+{{ addi_opcode }} pair (static code model).
def : Pat<(add (i{{ xlen }} ({{ ISA }}ISD_HI tglobaladdr:$in)), (i{{ xlen }} ({{ ISA }}ISD_LO tglobaladdr:$in))),
          ({{ addi_opcode }} ({{ lui_opcode }} tglobaladdr:$in), tglobaladdr:$in)>;
def : Pat<(add (i{{ xlen }} ({{ ISA }}ISD_HI texternalsym:$in)), (i{{ xlen }} ({{ ISA }}ISD_LO texternalsym:$in))),
          ({{ addi_opcode }} ({{ lui_opcode }} texternalsym:$in), texternalsym:$in)>;
{% endif %}

{% if cmp_branch_path %}
// ── Compare-then-branch control flow (no direct ordering compare-branches) ───
// setlt/setult are matched by the SLT/SLTU instruction patterns themselves.
// seteq/setne have no native instruction → compute (a^b) then test against 0.
{% if xor_opcode and sltiu_opcode %}
def : Pat<(seteq {{ first_reg_class }}:$a, {{ first_reg_class }}:$b),
          ({{ sltiu_opcode }} ({{ xor_opcode }} {{ first_reg_class }}:$a, {{ first_reg_class }}:$b), 1)>;
{% endif %}
{% if xor_opcode and sltu_opcode %}
def : Pat<(setne {{ first_reg_class }}:$a, {{ first_reg_class }}:$b),
          ({{ sltu_opcode }} {{ zero_reg }}, ({{ xor_opcode }} {{ first_reg_class }}:$a, {{ first_reg_class }}:$b))>;
{% endif %}
{% if sltiu_opcode %}
def : Pat<(seteq {{ first_reg_class }}:$a, 0), ({{ sltiu_opcode }} {{ first_reg_class }}:$a, 1)>;
{% endif %}
{% if sltu_opcode %}
def : Pat<(setne {{ first_reg_class }}:$a, 0), ({{ sltu_opcode }} {{ zero_reg }}, {{ first_reg_class }}:$a)>;
{% endif %}
// Branch on a 0/1 condition value held in a register.
def : Pat<(brcond {{ first_reg_class }}:$cond, bb:$target),
          ({{ bne_opcode }} {{ first_reg_class }}:$cond, {{ zero_reg }}, brtarget:$target)>;
{% endif %}

// ── Pseudo-instruction base class ────────────────────────────────────────────
class {{ ISA }}Pseudo<dag outs, dag ins, list<dag> pattern>
    : {{ ISA }}Inst<outs, ins, "", pattern> {
  let isPseudo = 1;
  let isCodeGenOnly = 1;
  let hasSideEffects = 0;
  let mayLoad = 0;
  let mayStore = 0;
}

// ── Control-flow pseudos (expanded to real JAL/JALR by the AsmPrinter) ───────
// These keep ISel out of fragile manual getMachineNode() wiring: the link
// register is fixed (ra for calls, the zero register for branch/return) and the
// target is a proper relocatable operand.
{% if jal_opcode and zero_reg %}
let isBranch = 1, isTerminator = 1, isBarrier = 1 in
def PseudoBR : {{ ISA }}Pseudo<(outs), (ins jaltarget:$imm), [(br bb:$imm)]>,
    PseudoInstExpansion<({{ jal_opcode }} {{ zero_reg }}, jaltarget:$imm)>;
{% endif %}
{% if jal_opcode and ra_reg %}
let isCall = 1, Defs = [{{ ra_reg }}] in
def PseudoCALL : {{ ISA }}Pseudo<(outs), (ins jaltarget:$func, variable_ops), []>,
    PseudoInstExpansion<({{ jal_opcode }} {{ ra_reg }}, jaltarget:$func)>;
{% endif %}
{% if jalr_opcode and ra_reg %}
let isCall = 1, Defs = [{{ ra_reg }}] in
def PseudoCALLIndirect : {{ ISA }}Pseudo<(outs), (ins {{ first_reg_class }}:$rs1, variable_ops), []>,
    PseudoInstExpansion<({{ jalr_opcode }} {{ ra_reg }}, {{ first_reg_class }}:$rs1, 0)>;
{% endif %}
{% if jalr_opcode and ra_reg and zero_reg %}
let isReturn = 1, isTerminator = 1, isBarrier = 1 in
def PseudoRET : {{ ISA }}Pseudo<(outs), (ins), []>,
    PseudoInstExpansion<({{ jalr_opcode }} {{ zero_reg }}, {{ ra_reg }}, 0)>;
{% endif %}

{% if has_select %}
// ── Conditional select (branch diamond via custom inserter) ──────────────────
let usesCustomInserter = 1 in
def Select_{{ first_reg_class }} : {{ ISA }}Pseudo<
    (outs {{ first_reg_class }}:$dst),
    (ins {{ first_reg_class }}:$cond, {{ first_reg_class }}:$t, {{ first_reg_class }}:$f),
    [(set {{ first_reg_class }}:$dst,
          ({{ ISA }}ISD_SELECTCC {{ first_reg_class }}:$cond,
                                 {{ first_reg_class }}:$t, {{ first_reg_class }}:$f))]>;
{% endif %}

{% if setcc_via_branch %}
// ── Materialize a comparison into a 0/1 register ─────────────────────────────
// This ISA has conditional branches but no set-less-than instruction, so a
// standalone comparison value (e.g. `int b = x < y;`) is built with a branch
// diamond by the custom inserter. Comparisons that feed a branch are matched by
// the compare-branch patterns above and never reach here.
let usesCustomInserter = 1 in
def PseudoSetCC : {{ ISA }}Pseudo<
    (outs {{ first_reg_class }}:$dst),
    (ins {{ first_reg_class }}:$lhs, {{ first_reg_class }}:$rhs, i32imm:$cc), []>;

{% for e in setcc_branch_entries %}
def : Pat<(i{{ xlen }} ({{ e.node }} {{ first_reg_class }}:$lhs, {{ first_reg_class }}:$rhs)),
          (PseudoSetCC {{ first_reg_class }}:$lhs, {{ first_reg_class }}:$rhs, {{ e.code }})>;
{% endfor %}
{% endif %}
