// {{ isa_name }} Register definitions — generated by isa-archive

class {{ ISA }}Reg<bits<16> Enc, string n, list<string> alt = []>
    : Register<n> {
  let HWEncoding = Enc;
  let AltNames = alt;
}

{% for reg in registers %}
// Register file: {{ reg.name }} ({{ reg.count }} x {{ reg.width }}-bit)
let Namespace = "{{ ISA }}" in {
{% for i in range(reg.count) %}
{%- set prefix = reg.prefix %}
{%- set aliases_for_i = [] %}
{%- for aname, aidx in reg.aliases.items() %}
{%- if aidx == i %}
{%- set _ = aliases_for_i.append(aname) %}
{%- endif %}
{%- endfor %}
  def {{ prefix }}{{ i }} : {{ ISA }}Reg<{{ i }}, "{{ prefix }}{{ i }}"
    {%- if aliases_for_i %}, [{% for a in aliases_for_i %}"{{ a }}"{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}>;
{% endfor %}
} // end Namespace

{%- set vts = reg_value_types[reg.name] %}
def {{ reg.name | upper }} : RegisterClass<"{{ ISA }}", [{{ vts | join(', ') }}], {{ reg.width }}, (add
{%- set prefix = reg.prefix %}
{%- set all_regs = [] %}
{%- for i in range(reg.count) %}
{%- set _ = all_regs.append(prefix ~ i) %}
{%- endfor %}
  {{ all_regs | join(', ') }}
)> {
{%- if reg.zero_register is not none %}
  let CopyCost = -1;  // x{{ reg.zero_register }} is hardwired zero
{%- endif %}
}

{% endfor %}
