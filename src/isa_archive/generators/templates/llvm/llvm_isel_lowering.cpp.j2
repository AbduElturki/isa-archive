{{ ISA }}TargetLowering::{{ ISA }}TargetLowering(const {{ ISA }}TargetMachine &TM,
                                                   const {{ ISA }}Subtarget &STI)
    : TargetLowering(TM), STI(STI) {
  // Set up register classes (one LLVM class per ISA register file)
{% for rc in reg_classes %}
{% for vt in rc.value_types %}
  addRegisterClass(MVT::{{ vt }}, &{{ ISA }}::{{ rc.class_name }}RegClass);
{% endfor %}
{% endfor %}
  computeRegisterProperties(STI.getRegisterInfo());

{% if sp_reg %}
  setStackPointerRegisterToSaveRestore({{ ISA }}::{{ sp_reg }});
{% endif %}
  setSchedulingPreference(Sched::RegPressure);

  // Comparisons (set-less-than and the branch-diamond materialization) produce
  // exactly 0 or 1, so a boolean used as an integer needs no `& 1` mask — which
  // would otherwise require an AND instruction the ISA may not have.
  setBooleanContents(ZeroOrOneBooleanContent);

  // Integer operations: Legal only when the ISA provides the instruction
  // (by compiler role); everything else is Expanded — to shifts/branches
  // where LLVM can, to libcalls (compiler-rt) for mul/div families. An op
  // must never default to Legal without an instruction behind it, or
  // instruction selection crashes instead of legalizing.
  for (auto VT : { {% for vt in int_value_types %}MVT::{{ vt }}{{ ", " if not loop.last else "" }}{% endfor %} }) {
{%- for op, role in [("ADD", "alu_rr.add"), ("SUB", "alu_rr.sub"), ("AND", "alu_rr.and"),
                     ("OR", "alu_rr.or"), ("XOR", "alu_rr.xor"), ("SHL", "alu_rr.shl"),
                     ("SRL", "alu_rr.srl"), ("SRA", "alu_rr.sra"), ("MUL", "alu_rr.mul")] %}
    setOperationAction(ISD::{{ "%-4s" | format(op) }}, VT, {{ "Legal" if role in compiler_roles else "Expand" }});
{%- endfor %}
    // No division/remainder/high-multiply instructions are modeled: libcalls.
    setOperationAction(ISD::SDIV,  VT, Expand);
    setOperationAction(ISD::UDIV,  VT, Expand);
    setOperationAction(ISD::SREM,  VT, Expand);
    setOperationAction(ISD::UREM,  VT, Expand);
    setOperationAction(ISD::SDIVREM, VT, Expand);
    setOperationAction(ISD::UDIVREM, VT, Expand);
    setOperationAction(ISD::MULHS, VT, Expand);
    setOperationAction(ISD::MULHU, VT, Expand);
    setOperationAction(ISD::SMUL_LOHI, VT, Expand);
    setOperationAction(ISD::UMUL_LOHI, VT, Expand);
    // Bit-manipulation ops with no role system yet: always synthesized.
    setOperationAction(ISD::ROTL,  VT, Expand);
    setOperationAction(ISD::ROTR,  VT, Expand);
    setOperationAction(ISD::BSWAP, VT, Expand);
    setOperationAction(ISD::CTLZ,  VT, Expand);
    setOperationAction(ISD::CTTZ,  VT, Expand);
    setOperationAction(ISD::CTPOP, VT, Expand);
    setOperationAction(ISD::LOAD,  VT, Legal);
    setOperationAction(ISD::STORE, VT, Legal);
  }

  // Sub-word memory access: only widths the ISA actually loads/stores are
  // legal; the rest are synthesized from full-width accesses (a byte store
  // on a word-only ISA becomes load-mask-store instead of an ISel crash).
{%- for w in [8, 16, 32] if w < xlen %}
{%- set has_store = ("mem.store" ~ w) in compiler_roles %}
{%- set has_load = ("mem.load" ~ w ~ "s") in compiler_roles or ("mem.load" ~ w ~ "u") in compiler_roles %}
{%- if not has_store %}
  setTruncStoreAction(MVT::i{{ xlen }}, MVT::i{{ w }}, Expand);
{%- endif %}
{%- if not has_load %}
  setLoadExtAction(ISD::EXTLOAD,  MVT::i{{ xlen }}, MVT::i{{ w }}, Expand);
  setLoadExtAction(ISD::SEXTLOAD, MVT::i{{ xlen }}, MVT::i{{ w }}, Expand);
  setLoadExtAction(ISD::ZEXTLOAD, MVT::i{{ xlen }}, MVT::i{{ w }}, Expand);
{%- endif %}
{%- endfor %}

{% if float_value_types %}
  // Floating-point: native arithmetic + load/store legal for each FP type present.
  for (auto VT : { {% for vt in float_value_types %}MVT::{{ vt }}{{ ", " if not loop.last else "" }}{% endfor %} }) {
    setOperationAction(ISD::FADD, VT, Legal);
    setOperationAction(ISD::FSUB, VT, Legal);
    setOperationAction(ISD::FMUL, VT, Legal);
    setOperationAction(ISD::FDIV, VT, Legal);
    setOperationAction(ISD::LOAD,  VT, Legal);
    setOperationAction(ISD::STORE, VT, Legal);
    // No native FP constant pool yet: materialize via integer bitpattern.
    setOperationAction(ISD::ConstantFP, VT, Expand);
  }
{% endif %}

{% if has_global_addr %}
  // GlobalAddress lowering ({{ lui_opcode }} + {{ addi_opcode }}, static code model)
  setOperationAction(ISD::GlobalAddress, MVT::i{{ xlen }}, Custom);
{% endif %}

  // Keep BRCOND and SETCC legal so Pat<(brcond ...)> patterns fire at ISel
  setOperationAction(ISD::BRCOND, MVT::Other, Legal);
  setOperationAction(ISD::SETCC,  MVT::i{{ xlen }}, Legal);

  // BR_CC → BRCOND + SETCC; SELECT_CC → SELECT + SETCC (matched by Pat<>/inserter).
  setOperationAction(ISD::BR_CC,     MVT::i{{ xlen }}, Expand);
  setOperationAction(ISD::SELECT_CC, MVT::i{{ xlen }}, Expand);
{% if cmp_branch_path %}
  // No direct ordering compare-branches. Reduce GT/GE/LE conditions to the
  // SETLT/SETULT forms implemented by the SLT/SLTU instructions; the legalizer
  // synthesizes the rest by swapping/inverting. SETEQ/SETNE are produced as a
  // 0/1 register by Pat<> (XOR + SLTIU), then a branch-on-(non)zero fires.
  for (auto CC : {ISD::SETGT, ISD::SETGE, ISD::SETLE,
                  ISD::SETUGT, ISD::SETUGE, ISD::SETULE})
    setCondCodeAction(CC, MVT::i{{ xlen }}, Expand);
{% endif %}
{% if has_select %}
  setOperationAction(ISD::SELECT, MVT::i{{ xlen }}, Custom);
{% else %}
  setOperationAction(ISD::SELECT, MVT::i{{ xlen }}, Expand);
{% endif %}
}

SDValue {{ ISA }}TargetLowering::LowerOperation(SDValue Op,
                                                  SelectionDAG &DAG) const {
  switch (Op.getOpcode()) {
{% if has_global_addr %}
  case ISD::GlobalAddress: return LowerGlobalAddress(Op, DAG);
{% endif %}
{% if has_select %}
  case ISD::SELECT:        return LowerSELECT(Op, DAG);
{% endif %}
  default:
    llvm_unreachable("{{ isa_name }}: unimplemented custom lowering");
  }
}

{% if has_select %}
SDValue {{ ISA }}TargetLowering::LowerSELECT(SDValue Op, SelectionDAG &DAG) const {
  SDLoc DL(Op);
  SDValue CondV  = Op.getOperand(0);
  SDValue TrueV  = Op.getOperand(1);
  SDValue FalseV = Op.getOperand(2);
  // Lower to a target node expanded into a branch diamond by the custom inserter.
  SDValue Ops[] = {CondV, TrueV, FalseV};
  return DAG.getNode({{ ISA }}ISD::SELECTCC, DL, Op.getValueType(), Ops);
}
{% endif %}

{% if needs_custom_inserter %}
MachineBasicBlock *{{ ISA }}TargetLowering::EmitInstrWithCustomInserter(
    MachineInstr &MI, MachineBasicBlock *BB) const {
  const TargetInstrInfo &TII = *BB->getParent()->getSubtarget().getInstrInfo();
  DebugLoc DL = MI.getDebugLoc();
  MachineFunction *MF = BB->getParent();
  const BasicBlock *LLVM_BB = BB->getBasicBlock();

  // Build a branch diamond:
  //   thisMBB:  <conditional branch to sinkMBB>
  //   copy0MBB: fallthrough
  //   sinkMBB:  dst = PHI [taken-value, thisMBB], [fallthrough-value, copy0MBB]
  MachineFunction::iterator It = ++BB->getIterator();
  MachineBasicBlock *thisMBB  = BB;
  MachineBasicBlock *copy0MBB = MF->CreateMachineBasicBlock(LLVM_BB);
  MachineBasicBlock *sinkMBB  = MF->CreateMachineBasicBlock(LLVM_BB);
  MF->insert(It, copy0MBB);
  MF->insert(It, sinkMBB);

  sinkMBB->splice(sinkMBB->begin(), BB,
                  std::next(MachineBasicBlock::iterator(MI)), BB->end());
  sinkMBB->transferSuccessorsAndUpdatePHIs(BB);
  thisMBB->addSuccessor(copy0MBB);
  thisMBB->addSuccessor(sinkMBB);
  copy0MBB->addSuccessor(sinkMBB);

  Register DstReg = MI.getOperand(0).getReg();

  switch (MI.getOpcode()) {
  default:
    llvm_unreachable("{{ isa_name }}: unexpected custom-inserter opcode");
{% if has_select %}
  case {{ ISA }}::Select_{{ first_reg_class }}: {
    // dst = (cond != 0) ? TrueV : FalseV
    Register CondReg  = MI.getOperand(1).getReg();
    Register TrueReg  = MI.getOperand(2).getReg();
    Register FalseReg = MI.getOperand(3).getReg();
    BuildMI(thisMBB, DL, TII.get({{ ISA }}::{{ bne_opcode }}))
        .addReg(CondReg).addReg({{ ISA }}::{{ zero_reg }}).addMBB(sinkMBB);
    BuildMI(*sinkMBB, sinkMBB->begin(), DL, TII.get(TargetOpcode::PHI), DstReg)
        .addReg(TrueReg).addMBB(thisMBB)
        .addReg(FalseReg).addMBB(copy0MBB);
    break;
  }
{% endif %}
{% if setcc_via_branch %}
  case {{ ISA }}::PseudoSetCC: {
    // dst = (lhs <cc> rhs) ? 1 : 0, realized by branching. This ISA has no
    // set-less-than instruction, so a comparison value is built with the same
    // conditional branches the compiler uses for control flow.
    Register Lhs = MI.getOperand(1).getReg();
    Register Rhs = MI.getOperand(2).getReg();
    int64_t CC   = MI.getOperand(3).getImm();

    MachineRegisterInfo &RegInfo = MF->getRegInfo();
    Register OneReg  = RegInfo.createVirtualRegister(&{{ ISA }}::{{ first_reg_class }}RegClass);
    Register ZeroReg = RegInfo.createVirtualRegister(&{{ ISA }}::{{ first_reg_class }}RegClass);
    BuildMI(thisMBB, DL, TII.get({{ ISA }}::{{ addi_opcode }}), OneReg)
        .addReg({{ ISA }}::{{ zero_reg }}).addImm(1);
    BuildMI(thisMBB, DL, TII.get({{ ISA }}::{{ addi_opcode }}), ZeroReg)
        .addReg({{ ISA }}::{{ zero_reg }}).addImm(0);

    unsigned BrOpc = 0;
    Register A = Lhs, B = Rhs;
    bool TakenOne = true;
    switch (CC) {
    default: llvm_unreachable("{{ isa_name }}: unhandled setcc code");
{% for e in setcc_branch_entries %}
    case {{ e.code }}: BrOpc = {{ ISA }}::{{ e.opcode }};{% if e.swap %} A = Rhs; B = Lhs;{% endif %} TakenOne = {{ "true" if e.taken_one else "false" }}; break;  // {{ e.node }}
{% endfor %}
    }

    // thisMBB: if (A <cc> B) goto sinkMBB
    BuildMI(thisMBB, DL, TII.get(BrOpc)).addReg(A).addReg(B).addMBB(sinkMBB);
    Register TakenReg = TakenOne ? OneReg : ZeroReg;   // value on the taken edge
    Register FallReg  = TakenOne ? ZeroReg : OneReg;   // value on the fallthrough edge
    BuildMI(*sinkMBB, sinkMBB->begin(), DL, TII.get(TargetOpcode::PHI), DstReg)
        .addReg(TakenReg).addMBB(thisMBB)
        .addReg(FallReg).addMBB(copy0MBB);
    break;
  }
{% endif %}
  }

  MI.eraseFromParent();
  return sinkMBB;
}
{% endif %}

{% if has_global_addr %}
SDValue {{ ISA }}TargetLowering::LowerGlobalAddress(SDValue Op,
                                                      SelectionDAG &DAG) const {
  SDLoc DL(Op);
  EVT Ty = getPointerTy(DAG.getDataLayout());
  auto *N = cast<GlobalAddressSDNode>(Op);

  SDValue Hi = DAG.getTargetGlobalAddress(N->getGlobal(), DL, Ty,
                                           N->getOffset(), {{ ISA }}II::MO_HI);
  SDValue Lo = DAG.getTargetGlobalAddress(N->getGlobal(), DL, Ty,
                                           N->getOffset(), {{ ISA }}II::MO_LO);
  // Use custom ISD nodes so TableGen can pattern-match to {{ lui_opcode }}+{{ addi_opcode }}.
  // getMachineNode() with TargetGlobalAddress operands is rejected by ISel
  // because TargetGlobalAddress is not a valid constant immediate leaf.
  SDValue HiPart = DAG.getNode({{ ISA }}ISD::HI, DL, Ty, Hi);
  SDValue LoPart = DAG.getNode({{ ISA }}ISD::LO, DL, Ty, Lo);
  return DAG.getNode(ISD::ADD, DL, Ty, HiPart, LoPart);
}
{% endif %}

const char *{{ ISA }}TargetLowering::getTargetNodeName(unsigned Opcode) const {
  switch (Opcode) {
{% if has_global_addr %}
  case {{ ISA }}ISD::HI:   return "{{ ISA }}ISD::HI";
  case {{ ISA }}ISD::LO:   return "{{ ISA }}ISD::LO";
{% endif %}
  case {{ ISA }}ISD::RET:  return "{{ ISA }}ISD::RET";
  case {{ ISA }}ISD::CALL: return "{{ ISA }}ISD::CALL";
{% if has_select %}
  case {{ ISA }}ISD::SELECTCC: return "{{ ISA }}ISD::SELECTCC";
{% endif %}
  default: return nullptr;
  }
}

// ── Argument lowering ──────────────────────────────────────────────────────

SDValue {{ ISA }}TargetLowering::LowerFormalArguments(
    SDValue Chain, CallingConv::ID CC, bool IsVarArg,
    const SmallVectorImpl<ISD::InputArg> &Ins, const SDLoc &DL,
    SelectionDAG &DAG, SmallVectorImpl<SDValue> &InVals) const {

  MachineFunction &MF = DAG.getMachineFunction();
  MachineRegisterInfo &RegInfo = MF.getRegInfo();

  SmallVector<CCValAssign, 16> ArgLocs;
  CCState CCInfo(CC, IsVarArg, MF, ArgLocs, *DAG.getContext());
  CCInfo.AnalyzeFormalArguments(Ins, CC_{{ ISA }});

  for (auto &VA : ArgLocs) {
    if (VA.isRegLoc()) {
      MVT RegVT = VA.getLocVT();
      Register VReg = RegInfo.createVirtualRegister(getRegClassFor(RegVT));
      MF.getRegInfo().addLiveIn(VA.getLocReg(), VReg);
      SDValue ArgIn = DAG.getCopyFromReg(Chain, DL, VReg, RegVT);
      InVals.push_back(ArgIn);
    } else {
      // Stack argument
      assert(VA.isMemLoc());
{% if sp_reg %}
      SDValue StackPtr = DAG.getCopyFromReg(Chain, DL, {{ ISA }}::{{ sp_reg }},
                                             getPointerTy(DAG.getDataLayout()));
{% else %}
      llvm_unreachable("Stack arguments require a stack pointer register (sp alias not defined in ISA)");
      SDValue StackPtr;
{% endif %}
      SDValue FI = DAG.getFrameIndex(
          MF.getFrameInfo().CreateFixedObject(VA.getLocVT().getSizeInBits() / 8,
                                              VA.getLocMemOffset(), true),
          getPointerTy(DAG.getDataLayout()));
      SDValue Load = DAG.getLoad(VA.getValVT(), DL, Chain, FI,
                                  MachinePointerInfo::getFixedStack(MF, 0));
      InVals.push_back(Load);
    }
  }
  return Chain;
}

// ── Return lowering ────────────────────────────────────────────────────────

SDValue {{ ISA }}TargetLowering::LowerReturn(
    SDValue Chain, CallingConv::ID CC, bool IsVarArg,
    const SmallVectorImpl<ISD::OutputArg> &Outs,
    const SmallVectorImpl<SDValue> &OutVals, const SDLoc &DL,
    SelectionDAG &DAG) const {

  SmallVector<CCValAssign, 16> RVLocs;
  CCState CCInfo(CC, IsVarArg, DAG.getMachineFunction(), RVLocs,
                  *DAG.getContext());
  CCInfo.AnalyzeReturn(Outs, RetCC_{{ ISA }});

  SDValue Flag;
  SmallVector<SDValue, 4> RetOps(1, Chain);

  for (unsigned i = 0, e = RVLocs.size(); i != e; ++i) {
    CCValAssign &VA = RVLocs[i];
    SDValue Val = OutVals[i];
    Chain = DAG.getCopyToReg(Chain, DL, VA.getLocReg(), Val, Flag);
    Flag = Chain.getValue(1);
    RetOps.push_back(DAG.getRegister(VA.getLocReg(), VA.getLocVT()));
  }

  RetOps[0] = Chain;
  if (Flag.getNode())
    RetOps.push_back(Flag);

  return DAG.getNode({{ ISA }}ISD::RET, DL, MVT::Other, RetOps);
}

// ── Call lowering ──────────────────────────────────────────────────────────

SDValue {{ ISA }}TargetLowering::LowerCall(CallLoweringInfo &CLI,
                                             SmallVectorImpl<SDValue> &InVals) const {
  // Minimal call lowering — direct calls only
  SelectionDAG &DAG = CLI.DAG;
  SDLoc &DL = CLI.DL;
  SmallVectorImpl<ISD::OutputArg> &Outs = CLI.Outs;
  SmallVectorImpl<SDValue> &OutVals = CLI.OutVals;
  SmallVectorImpl<ISD::InputArg> &Ins = CLI.Ins;
  SDValue Chain = CLI.Chain;
  SDValue Callee = CLI.Callee;
  CallingConv::ID CC = CLI.CallConv;
  bool IsVarArg = CLI.IsVarArg;
  MachineFunction &MF = DAG.getMachineFunction();

  // For direct calls, preserve the symbol as a target address (for JAL reloc).
  // LowerGlobalAddress would materialise it via LUI+ADDI which is wrong for calls.
  EVT Ty = getPointerTy(DAG.getDataLayout());
  if (GlobalAddressSDNode *GA = dyn_cast<GlobalAddressSDNode>(Callee))
    Callee = DAG.getTargetGlobalAddress(GA->getGlobal(), DL, Ty, GA->getOffset());
  else if (ExternalSymbolSDNode *ES = dyn_cast<ExternalSymbolSDNode>(Callee))
    Callee = DAG.getTargetExternalSymbol(ES->getSymbol(), Ty);

  SmallVector<CCValAssign, 16> ArgLocs;
  CCState CCInfo(CC, IsVarArg, MF, ArgLocs, *DAG.getContext());
  CCInfo.AnalyzeCallOperands(Outs, CC_{{ ISA }});

  SDValue Flag;
  SmallVector<SDValue, 8> Ops;
  Ops.push_back(Chain);
  Ops.push_back(Callee);

  for (unsigned i = 0, e = ArgLocs.size(); i != e; ++i) {
    CCValAssign &VA = ArgLocs[i];
    SDValue Arg = OutVals[i];
    Chain = DAG.getCopyToReg(Chain, DL, VA.getLocReg(), Arg, Flag);
    Ops.push_back(DAG.getRegister(VA.getLocReg(), VA.getLocVT()));
    Flag = Chain.getValue(1);
  }
  Ops[0] = Chain;
  if (Flag.getNode())
    Ops.push_back(Flag);

  SDVTList NodeTys = DAG.getVTList(MVT::Other, MVT::Glue);
  Chain = DAG.getNode({{ ISA }}ISD::CALL, DL, NodeTys, Ops);
  Flag = Chain.getValue(1);

  // Handle return values
  SmallVector<CCValAssign, 16> RVLocs;
  CCState RetCCInfo(CC, IsVarArg, MF, RVLocs, *DAG.getContext());
  RetCCInfo.AnalyzeCallResult(Ins, RetCC_{{ ISA }});

  for (auto &VA : RVLocs) {
    SDValue Val = DAG.getCopyFromReg(Chain, DL, VA.getLocReg(),
                                      VA.getLocVT(), Flag);
    Chain = Val.getValue(1);
    Flag  = Val.getValue(2);
    InVals.push_back(Val);
  }
  return Chain;
}
