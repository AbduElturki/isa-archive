char {{ ISA }}DAGToDAGISel::ID = 0;

void {{ ISA }}DAGToDAGISel::Select(SDNode *Node) {
  SDLoc DL(Node);

{% if addi_opcode %}
  // A frame address used as a value (e.g. the address of a stack local):
  // materialize as {{ addi_opcode }} frameindex, 0 — eliminateFrameIndex later
  // rewrites it into an SP-relative form.
  if (Node->getOpcode() == ISD::FrameIndex) {
    int FI = cast<FrameIndexSDNode>(Node)->getIndex();
    SDValue TFI = CurDAG->getTargetFrameIndex(FI, MVT::i{{ xlen }});
    SDValue Zero = CurDAG->getTargetConstant(0, DL, MVT::i{{ xlen }});
    ReplaceNode(Node, CurDAG->getMachineNode({{ ISA }}::{{ addi_opcode }}, DL,
                                             MVT::i{{ xlen }}, TFI, Zero));
    return;
  }
{% endif %}

  if (Node->getOpcode() == ISD::Constant) {
    int64_t Imm = cast<ConstantSDNode>(Node)->getSExtValue();
{% if zero_reg and addi_opcode %}
    // Small signed constant fits the add-immediate field: ADDI-from-zero.
    if (isInt<{{ addi_width }}>(Imm)) {
      SDValue Zero = CurDAG->getRegister({{ ISA }}::{{ zero_reg }}, MVT::i{{ xlen }});
      SDValue ImmV = CurDAG->getTargetConstant(Imm, DL, MVT::i{{ xlen }});
      ReplaceNode(Node, CurDAG->getMachineNode({{ ISA }}::{{ addi_opcode }}, DL,
                                               MVT::i{{ xlen }}, Zero, ImmV));
      return;
    }
{% endif %}
{% if const_strategy == "single_imm" and const_load_opcode %}
    // single_imm strategy: one load-immediate instruction covers the full word.
    {
      SDValue ImmV = CurDAG->getTargetConstant(Imm, DL, MVT::i{{ xlen }});
      ReplaceNode(Node, CurDAG->getMachineNode({{ ISA }}::{{ const_load_opcode }}, DL,
                                               MVT::i{{ xlen }}, ImmV));
      return;
    }
{% elif const_strategy == "hi_lo_or" and const_hi_opcode and const_lo_opcode %}
    // hi_lo_or strategy: high part via {{ const_hi_opcode }}, low part OR-ed in
    // (zero-extended low — no sign-compensation needed).
    int64_t Hi = ((uint64_t)Imm >> {{ addi_width }}) & {{ lui_mask }};
    int64_t Lo = (uint64_t)Imm & {{ lo_mask }};
    SDValue HiV = CurDAG->getTargetConstant(Hi, DL, MVT::i{{ xlen }});
    SDNode *HiN = CurDAG->getMachineNode({{ ISA }}::{{ const_hi_opcode }}, DL,
                                         MVT::i{{ xlen }}, HiV);
    if (Lo == 0) {
      ReplaceNode(Node, HiN);
      return;
    }
    SDValue LoV = CurDAG->getTargetConstant(Lo, DL, MVT::i{{ xlen }});
    ReplaceNode(Node, CurDAG->getMachineNode({{ ISA }}::{{ const_lo_opcode }}, DL,
                                             MVT::i{{ xlen }},
                                             SDValue(HiN, 0), LoV));
    return;
{% elif const_hi_opcode %}
    // hi_lo_add strategy: high part via {{ const_hi_opcode }}, sign-extended low
    // added in (+{{ lui_compensator }} compensates for low-part sign extension).
    int64_t Hi = ((Imm + {{ lui_compensator }}) >> {{ addi_width }}) & {{ lui_mask }};
    int64_t Lo = SignExtend64<{{ addi_width }}>(Imm & {{ lo_mask }});
    SDValue HiV = CurDAG->getTargetConstant(Hi, DL, MVT::i{{ xlen }});
    SDNode *LuiN = CurDAG->getMachineNode({{ ISA }}::{{ const_hi_opcode }}, DL,
                                          MVT::i{{ xlen }}, HiV);
{% if const_lo_opcode %}
    if (Lo == 0) {
      ReplaceNode(Node, LuiN);
      return;
    }
    SDValue LoV = CurDAG->getTargetConstant(Lo, DL, MVT::i{{ xlen }});
    ReplaceNode(Node, CurDAG->getMachineNode({{ ISA }}::{{ const_lo_opcode }}, DL,
                                             MVT::i{{ xlen }},
                                             SDValue(LuiN, 0), LoV));
{% else %}
    ReplaceNode(Node, LuiN);
{% endif %}
    return;
{% endif %}
  }

{% if ra_reg and jalr_opcode and zero_reg %}
  // Handle return: PseudoRET (expands to JALR zero, ra, 0).
  if (Node->getOpcode() == {{ ISA }}ISD::RET) {
    SmallVector<SDValue, 2> Ops{Node->getOperand(0)};  // chain
    if (Node->getNumOperands() > 1 &&
        Node->getOperand(Node->getNumOperands() - 1).getValueType() == MVT::Glue)
      Ops.push_back(Node->getOperand(Node->getNumOperands() - 1));
    SDNode *Ret = CurDAG->getMachineNode({{ ISA }}::PseudoRET, DL, MVT::Other, Ops);
    CurDAG->ReplaceAllUsesWith(SDValue(Node, 0), SDValue(Ret, 0));
    CurDAG->RemoveDeadNode(Node);
    return;
  }
{% endif %}

  // ISD::BR is selected by the PseudoBR Pat<(br bb)> pattern (no manual handling).

{% if jal_opcode and jalr_opcode and ra_reg %}
  // Handle call: direct → PseudoCALL (JAL ra), indirect → PseudoCALLIndirect (JALR ra).
  if (Node->getOpcode() == {{ ISA }}ISD::CALL) {
    SDValue Chain  = Node->getOperand(0);
    SDValue Callee = Node->getOperand(1);
    bool IsDirect = isa<GlobalAddressSDNode>(Callee) ||
                    isa<ExternalSymbolSDNode>(Callee);
    // Operands: callee, then the argument-register uses, then chain, then glue.
    SmallVector<SDValue, 8> Ops{Callee};
    for (unsigned i = 2; i < Node->getNumOperands(); ++i)
      if (Node->getOperand(i).getValueType() != MVT::Glue)
        Ops.push_back(Node->getOperand(i));
    Ops.push_back(Chain);
    for (unsigned i = 2; i < Node->getNumOperands(); ++i)
      if (Node->getOperand(i).getValueType() == MVT::Glue)
        Ops.push_back(Node->getOperand(i));
    unsigned CallOpc = IsDirect ? {{ ISA }}::PseudoCALL
                                : {{ ISA }}::PseudoCALLIndirect;
    SDNode *Call = CurDAG->getMachineNode(CallOpc, DL,
        MVT::Other, MVT::Glue, Ops);
    CurDAG->ReplaceAllUsesWith(Node, Call);
    CurDAG->RemoveDeadNode(Node);
    return;
  }
{% endif %}

  SelectCode(Node);
}

bool {{ ISA }}DAGToDAGISel::SelectInlineAsmMemoryOperand(
    const SDValue &Op, InlineAsm::ConstraintCode ConstraintID,
    std::vector<SDValue> &OutOps) {
  OutOps.push_back(Op);
  return false;
}

