#!/usr/bin/env bash
# patch_llvm.sh — idempotent: integrates every generated target in this
# directory into an LLVM source tree (a registry with an `extends:` chain
# generates one backend per ISA — base and extension are both handled).
# Usage: bash patch_llvm.sh <path-to-llvm-project-root>
# Generated by isa-archive

set -euo pipefail

LLVM_SRC="${1:?Usage: $0 <path-to-llvm-project-root>}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_CMAKE="$LLVM_SRC/llvm/CMakeLists.txt"

if [ ! -d "$LLVM_SRC/llvm/lib/Target" ]; then
  echo "ERROR: $LLVM_SRC does not look like an LLVM source tree." >&2
  exit 1
fi

ALL_TARGETS=""
for tgt_path in "$SCRIPT_DIR"/llvm/lib/Target/*/; do
  ISA_UPPER="$(basename "$tgt_path")"
  ALL_TARGETS="${ALL_TARGETS:+$ALL_TARGETS;}$ISA_UPPER"
  TARGET_DIR="$LLVM_SRC/llvm/lib/Target/$ISA_UPPER"

  echo "==> Copying $ISA_UPPER target files …"
  mkdir -p "$TARGET_DIR"
  cp -r "$tgt_path"* "$TARGET_DIR/"

  # ── patch llvm/CMakeLists.txt — LLVM_ALL_TARGETS ───────────────────────────
  # Note: lib/Target/CMakeLists.txt already has `foreach(t ${LLVM_TARGETS_TO_BUILD})
  # add_subdirectory(${t})`, so we only need to add ISA_UPPER to LLVM_ALL_TARGETS.
  # Do NOT add a manual add_subdirectory — that would create a duplicate.
  # The match is anchored to the whole line so e.g. PICO32 doesn't shadow PICO32M.
  if ! grep -Eq "^[[:space:]]*${ISA_UPPER}[[:space:]]*$" "$ROOT_CMAKE"; then
    echo "==> Inserting $ISA_UPPER into LLVM_ALL_TARGETS in $ROOT_CMAKE"
    awk -v isa="$ISA_UPPER" '
      in_targets && /^[[:space:]]*\)/ { print "  " isa; in_targets=0 }
      /set\(LLVM_ALL_TARGETS/ { in_targets=1 }
      1
    ' "$ROOT_CMAKE" > "${ROOT_CMAKE}.tmp"
    mv "${ROOT_CMAKE}.tmp" "$ROOT_CMAKE"
  else
    echo "==> $ROOT_CMAKE already lists $ISA_UPPER (skipping)"
  fi
done

echo ""
echo "Done. Now configure LLVM:"
echo ""
echo "  cmake -G Ninja -B build \\
        -DLLVM_TARGETS_TO_BUILD=\"$ALL_TARGETS\" \\
        -DCMAKE_BUILD_TYPE=Release \\
        $LLVM_SRC/llvm"
echo "  ninja -C build llc"
